    <command:details>
      <command:name>Register-LiquidTrustedType</command:name>
      <command:verb>Register</command:verb>
      <command:noun>LiquidTrustedType</command:noun>
      <maml:description>
        <maml:para>Registers a trusted CLR type for object-property access.</maml:para>
      </maml:description>
    </command:details>
    <maml:description>
      <maml:para>By default, PowerLiquid sanitizes host-provided data down to inert scalars, collections, hashtables, and note-property objects. If a host application wants to expose a specific CLR type's public properties to templates, it must opt in explicitly by registering that type as trusted.</maml:para>
      <maml:para>This keeps untrusted input safe by default while still allowing trusted host models, such as strongly-typed document objects, to participate in templates.</maml:para>
    </maml:description>
    <command:syntax>
      <command:syntaxItem>
        <maml:name>Register-LiquidTrustedType</maml:name>
        <command:parameter required="true" variableLength="true" globbing="false" pipelineInput="False" position="1" aliases="none">
          <maml:name>Registry</maml:name>
          <maml:description>
            <maml:para>The extension registry created by New-LiquidExtensionRegistry.</maml:para>
          </maml:description>
          <command:parameterValue required="true" variableLength="false">Hashtable</command:parameterValue>
          <dev:type>
            <maml:name>Hashtable</maml:name>
            <maml:uri />
          </dev:type>
          <dev:defaultValue>None</dev:defaultValue>
        </command:parameter>
        <command:parameter required="true" variableLength="true" globbing="false" pipelineInput="False" position="2" aliases="none">
          <maml:name>TypeName</maml:name>
          <maml:description>
            <maml:para>The CLR type name to trust. Both full names and short names are matched.</maml:para>
          </maml:description>
          <command:parameterValue required="true" variableLength="false">String</command:parameterValue>
          <dev:type>
            <maml:name>String</maml:name>
            <maml:uri />
          </dev:type>
          <dev:defaultValue>None</dev:defaultValue>
        </command:parameter>
      </command:syntaxItem>
    </command:syntax>
